  },
  "output": {
    "save_raw_trends": true,
    "save_generated_ideas": true,
    "idea_format": "txt"
  },
  "video_creation": {
    "enabled": true,
    "duration_seconds": 3,
    "resolution": [1080, 1920],
    "fps": 24,
    "background_color": "#1a1a2e",
    "text_color": "#ffffff",
    "font_size": 70,
    "font": "",
    "enable_fade": true,
    "fade_duration": 0.5,
    "enable_background_music": false,
    "background_music_path": ""
  }
