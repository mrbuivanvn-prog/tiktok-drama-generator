{
  "sources": {
    "google_trends": {
      "enabled": false,
      "keywords": ["drama", "tiktok", "trending"],
      "geo": "VN",
      "timeframe": "now 1-d"
    },
    "reddit": {
      "enabled": false,
      "subreddits": ["drama", "tiktok", "Vietnam"],
      "limit": 25
    },
    "twitter": {
      "enabled": false,
      "keywords": ["drama", "tiktok", "hot"],
      "lang": "vi",
      "count": 50
    },
    "facebook": {
      "enabled": false,
      "access_token": "",
      "pages": [
        {"name": "Example Page", "id": "page_id_here"}
      ]
    },
    "web_scraping": {
      "enabled": true,
      "sites": [
        {
          "name": "Zing News",
          "url": "https://zingnews.vn/",
          "section": "giai-tri"
        },
        {
          "name": "VietNamNet",
          "url": "https://vietnamnet.vn/",
          "section": "giai-tri"
        }
      ]
