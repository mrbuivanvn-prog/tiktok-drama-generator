  "generation": {
    "video_style": "short_form",
    "max_duration_seconds": 60,
    "language": "vi",
    "templates": [
      "Xu hướng {topic} ngày hôm nay - bạn có biết không?",
      "3 điều surprenant về {topic} mà ít người biết",
